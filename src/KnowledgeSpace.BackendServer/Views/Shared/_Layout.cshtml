@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.ViewEngines
@using KnowledgeSpace.BackendServer.Data.Entities
@inject IWebHostEnvironment Environment
@inject ICompositeViewEngine Engine
@inject SignInManager<User> SignInManager
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UniRide</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        .sidebar { min-height: calc(100vh - 56px); }
        .sidebar .nav-link { color: #333; padding: 10px 20px; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background-color: #e9ecef; color: #0d6efd; }
        .sidebar .nav-link i { width: 24px; }
        .content-wrapper { min-height: calc(100vh - 56px); }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-primary border-bottom box-shadow">
            <div class="container-fluid">
                <a class="navbar-brand" href="~/">🚗 UniRide</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index"><i class="bi bi-house"></i> Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/swagger"><i class="bi bi-code-slash"></i> Swagger</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    @if (SignInManager.IsSignedIn(User))
    {
        <div class="container-fluid">
            <div class="row">
                <nav class="col-md-2 d-none d-md-block bg-light sidebar border-end pt-3">
                    <div class="position-sticky">
                        <h6 class="sidebar-heading px-3 mt-1 mb-2 text-muted"><i class="bi bi-speedometer2"></i> Chức năng</h6>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Trips"><i class="bi bi-signpost-2"></i> Chuyến đi</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Bookings"><i class="bi bi-journal-check"></i> Đặt chỗ</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Vehicles"><i class="bi bi-car-front"></i> Phương tiện</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Ratings"><i class="bi bi-star"></i> Đánh giá</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Payments"><i class="bi bi-credit-card"></i> Thanh toán</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="PayoutProfile"><i class="bi bi-bank"></i> Tài khoản NH</a>
                            </li>
                        </ul>
                        <h6 class="sidebar-heading px-3 mt-3 mb-2 text-muted"><i class="bi bi-shield-lock"></i> Quản trị</h6>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Users"><i class="bi bi-people"></i> Người dùng</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Reports"><i class="bi bi-flag"></i> Báo cáo</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Organizations"><i class="bi bi-building"></i> Tổ chức</a>
                            </li>
                        </ul>
                    </div>
                </nav>
                <main class="col-md-10 ms-sm-auto px-4 py-3 content-wrapper">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <div class="container py-3">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
